/bin/zsh -lc "python - <<'PY'
import re
from pathlib import Path
text = Path('refs/2511.13936/tex_src/manuscript.bbl').read_text()
entries = re.split(r'\\\\bibitem\\[["'^'"\\]]*\\]\\s*%\\s*\\n\\s*\\{', text)[1:]
for i,chunk in enumerate(entries,1):
    key, rest = chunk.split('}',1)
    year = re.search(r'\\\\bibinfo\\{year\\}\\{(["'^}]*)'"\\}', rest)
    title = re.search(r'\\\\showarticletitle\\{(["'^}]*)'"\\}', rest)
    authors = []
    m = re.search(r'\\\\bibfield\\{author\\}\\{(.*?)\\}\\s*\\\\bibinfo\\{year\\}', rest, re.S)
    if m:
        auth_blob = m.group(1)
        authors = re.findall(r'\\\\bibinfo\\{person\\}\\{(["'^}]*)'"\\}', auth_blob)
    venue = None
    for pat in [r'\\\\bibinfo\\{journal\\}\\{\\\\emph\\{(["'^}]*)'"\\}\\}', r'\\\\bibinfo\\{booktitle\\}\\{\\\\emph\\{(["'^}]*)'"\\}\\}', r'\\\\bibinfo\\{booktitle\\}\\{(["'^}]*)'"\\}', r'\\\\bibinfo\\{journal\\}\\{(["'^}]*)'"\\}']:
        vm = re.search(pat, rest)
        if vm:
            venue = vm.group(1)
            break
    print(f\"{i:02d}\\t{key}\\t{year.group(1) if year else ''}\\t{title.group(1) if title else ''}\\t{venue or ''}\\t{'; '.join(authors[:3])}{' et al.' if len(authors)>3 else ''}\")
